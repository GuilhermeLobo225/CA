# SmartHandover - environment variables for the synthetic-data pipeline.
#
# Copy this file to `.env` and fill in real keys. The pipeline scripts
# call `load_dotenv()` before any API request, so anything you set here
# is picked up automatically. The .env file is gitignored.

# ============================================================
# Text generation - IAEDU pool
# ============================================================
# Preferred path: fill configs/iaedu_accounts.json with the (key, channel_id)
# pairs (see configs/iaedu_accounts.example.json). When that file has live
# entries, the text pool uses IAEDU automatically and ignores OPENAI_API_KEYS.
#
# OpenAI fallback - only used if iaedu_accounts.json is missing/empty:
# OPENAI_API_KEYS=sk-proj-...,sk-proj-...
# OPENAI_BASE_URL=https://api.openai.com/v1   # optional override

# Model name as published by the IAEDU agent (or by your fallback proxy).
SYNTH_TEXT_MODEL=gpt-4o

# ============================================================
# LLM judge - independent model for filter_text.py
# ============================================================
# Provider: "ollama" (default, local), "iaedu" (reuse text pool, biased),
# or "openai" (paid).
JUDGE_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434/v1

# Recommended judge models (in order of quality on a 16 GB GPU):
#   mistral-small3.1:latest   24B, ~14 GB Q4, top quality + JSON  (default)
#   gemma3:27b                27B, ~17 GB Q4, borderline (may offload to CPU)
#   phi4:latest               14B, ~9 GB Q4, very fast, good reasoning
#   qwen3:14b                 14B, ~9 GB Q4, strong on structured output
#   llama3.2:latest           3B,  ~3 GB,    fastest, lower quality
SYNTH_JUDGE_MODEL=mistral-small3.1:latest

# ============================================================
# Text-to-speech - TTS pool
# ============================================================
# IAEDU is chat-only, so TTS goes through the regular paid OpenAI account.
# Leave OPENAI_TTS_API_KEY unset to fall back to the first text key.
OPENAI_TTS_API_KEY=sk-direct-openai-key-here
OPENAI_TTS_BASE_URL=https://api.openai.com/v1
SYNTH_TTS_MODEL=gpt-4o-mini-tts

# ============================================================
# Run-time tuning (optional)
# ============================================================
SYNTH_TEXT_CONCURRENCY=8
# Ollama defaults to 2 - higher just queues on the single GPU.
# SYNTH_JUDGE_CONCURRENCY=2
SYNTH_AUDIO_CONCURRENCY=4
SYNTH_SEED=42
